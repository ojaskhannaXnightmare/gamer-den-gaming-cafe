// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User Model for Authentication
model User {
  id           String    @id @default(cuid())
  username     String    @unique
  password     String
  email        String?   @unique
  phone        String?
  name         String?
  avatar       String?
  points       Int       @default(0)
  totalSpent   Float     @default(0)
  isAdmin      Boolean   @default(false)
  bookings     Booking[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// Gaming Console Types
model Console {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  pricePerHour Float
  image       String?
  features    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  slots       Slot[]
  bookings    Booking[]
}

// Time Slots for each console
model Slot {
  id          String   @id @default(cuid())
  consoleId   String
  console     Console  @relation(fields: [consoleId], references: [id])
  startTime   String
  endTime     String
  isAvailable Boolean  @default(true)
  dayOfWeek   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bookings    Booking[]

  @@unique([consoleId, startTime, dayOfWeek])
}

// Game Library
model Game {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  genre       String
  consoleType String?
  image       String?
  rating      Float?
  isFeatured  Boolean  @default(false)
  isPopular   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Booking System
model Booking {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  consoleId     String
  console       Console   @relation(fields: [consoleId], references: [id])
  slotId        String
  slot          Slot      @relation(fields: [slotId], references: [id])
  customerName  String
  customerPhone String
  customerEmail String?
  date          String
  startTime     String
  endTime       String
  duration      Int
  players       Int       @default(1)
  totalPrice    Float
  status        String    @default("pending")
  paymentMethod String?
  paymentStatus String    @default("pending")
  transactionId String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Events and Tournaments
model Event {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String?
  gameName      String?
  date          String
  time          String
  endDate       String?
  prize         String?
  maxPlayers    Int?
  currentPlayers Int    @default(0)
  price         Float    @default(0)
  image         String?
  status        String   @default("upcoming")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Gallery Images/Videos
model GalleryItem {
  id          String   @id @default(cuid())
  title       String?
  description String?
  type        String
  url         String
  thumbnail   String?
  category    String?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Announcements / Updates
model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   @default("info")
  isActive  Boolean  @default(true)
  startDate String?
  endDate   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Pricing Packages
model PricingPackage {
  id          String   @id @default(cuid())
  name        String
  description String?
  consoleType String
  price       Float
  duration    Int
  discount    Float?
  includes    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Contact Messages
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
